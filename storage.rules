rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Bill PDF storage
    match /bills/{meterId}/{fileName} {
      // Admin can read and write
      allow read, write: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // Consumer can read their own bills
      allow read: if request.auth != null
        && firestore.get(/databases/(default)/documents/meters/$(meterId)).data.assignedTo == request.auth.uid;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
